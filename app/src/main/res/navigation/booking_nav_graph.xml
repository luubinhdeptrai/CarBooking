<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/booking_nav_graph"
    app:startDestination="@id/searchTripFragment">

    <fragment
        android:id="@+id/searchTripFragment"
        android:name="com.example.login.VIEW.SearchTripFragment"
        android:label="Tìm Chuyến Xe" tools:layout="@layout/fragment_search_trip">
        <action
            android:id="@+id/action_searchTrip_to_selectTrip" app:destination="@id/selectTripFragment" />
        <argument
            android:name="originCity"
            app:argType="string" />
        <argument
            android:name="destinationCity"
            app:argType="string" />
        <argument
            android:name="departureDate"
            app:argType="string" />
        <argument
            android:name="searchResults"
            app:argType="com.example.login.MODELS.TripSearchResult[]"
            app:nullable="true" />
    </fragment>

    <fragment
        android:id="@+id/selectTripFragment"
        android:name="com.example.login.VIEW.SelectTripFragment"
        android:label="Kết quả tìm kiếm chuyến" tools:layout="@layout/fragment_select_trip"> <action
        android:id="@+id/action_selectTrip_to_selectSeat"
        app:destination="@id/selectSeatFragment" />
        <argument
            android:name="originCity"
            app:argType="string" />
        <argument
            android:name="destinationCity"
            app:argType="string" />
        <argument
            android:name="departureDate"
            app:argType="string" />
        <argument
            android:name="searchResults"
            app:argType="com.example.login.MODELS.TripSearchResult[]"
            app:nullable="true" />
    </fragment>

    <fragment
        android:id="@+id/selectSeatFragment"
        android:name="com.example.login.VIEW.SelectSeatFragment"
        android:label="Chọn Ghế" tools:layout="@layout/fragment_select_seat">
        <action
            android:id="@+id/action_selectSeat_to_confirmation"
            app:destination="@id/confirmationFragment" />
    </fragment>

    <fragment
        android:id="@+id/confirmationFragment"
        android:name="com.example.login.VIEW.ConfirmationFragment"
        android:label="Xác nhận Đặt vé" tools:layout="@layout/fragment_confirmation" >
        <action
            android:id="@+id/action_confirmation_to_payment"
            app:destination="@id/paymentFragment" />
    </fragment>

    <fragment
        android:id="@+id/paymentFragment"
        android:name="com.example.login.VIEW.PaymentFragment"
        android:label="Thanh toán" tools:layout="@layout/fragment_payment" />

</navigation>