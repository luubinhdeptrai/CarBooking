<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/booking_nav_graph"
    app:startDestination="@id/buyTicketFragment">

    <fragment
        android:id="@+id/buyTicketFragment"
        android:name="com.example.login.VIEW.BuyTicketFragment"
        android:label="Buy Ticket"
        tools:layout="@layout/fragment_buy_ticket">
        <action
            android:id="@+id/action_buyTicket_to_selectTrip"
            app:destination="@id/selectTripFragment" />
    </fragment>

    <fragment
        android:id="@+id/selectTripFragment"
        android:name="com.example.login.VIEW.SelectTripFragment"
        android:label="Select Trip"
        tools:layout="@layout/fragment_select_trip">
        <action
            android:id="@+id/action_selectTrip_to_selectSeat"
            app:destination="@id/selectSeatFragment" />
    </fragment>

    <fragment
        android:id="@+id/selectSeatFragment"
        android:name="com.example.login.VIEW.SelectSeatFragment"
        android:label="Select Seat"
        tools:layout="@layout/fragment_select_seat">
        <action
            android:id="@+id/action_selectSeat_to_confirmation"
            app:destination="@id/confirmationFragment" />
    </fragment>

    <fragment
        android:id="@+id/confirmationFragment"
        android:name="com.example.login.VIEW.ConfirmationFragment"
        android:label="Confirmation"
        tools:layout="@layout/fragment_confirmation" />

</navigation>