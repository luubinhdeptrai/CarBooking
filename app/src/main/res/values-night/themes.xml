<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme for Night Mode using Material 3. -->
    <style name="Theme.BookingApp" parent="Theme.Material3.Dark.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/orange_primary</item>
        <item name="colorPrimaryContainer">@color/orange_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/orange_light</item>
        <item name="colorSecondaryContainer">@color/orange_light</item>
        <item name="colorOnSecondary">@color/black</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor">?attr/colorPrimary</item>
        <!-- Customize your theme here. -->
    </style>
    <style name="AppDatePickerTheme" parent="Theme.AppCompat.Light.Dialog">
        <item name="colorAccent">@color/orange_primary</item>
        <item name="android:windowBackground">@color/white</item>
        <item name="android:headerBackground">@color/orange_primary</item>
    </style>
</resources>
    