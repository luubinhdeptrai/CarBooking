<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    app:cardCornerRadius="8dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/tv_issue_title_item"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            tools:text="Vấn đề về đăng nhập tài khoản"
            android:textColor="@color/text_primary"
            android:textSize="16sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/tv_issue_description_item"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            tools:text="Tôi không thể đăng nhập vào tài khoản của mình sau khi cập nhật ứng dụng."
            android:textColor="@color/text_secondary"
            android:maxLines="2"
            android:ellipsize="end"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tv_issue_type_item"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                tools:text="technical"
                android:textColor="@color/orange_primary"
                android:background="@drawable/rounded_tag_background"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:textSize="12sp"/>

            <TextView
                android:id="@+id/tv_issue_status_item"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                tools:text="pending"
                android:textColor="@color/white"
                android:background="@drawable/rounded_status_background_pending"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:textSize="12sp"
                android:layout_marginStart="8dp"/>

            <TextView
                android:id="@+id/tv_issue_date_item"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                tools:text="2024-07-03"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:gravity="end" />

        </LinearLayout>
    </LinearLayout>

</androidx.cardview.widget.CardView>