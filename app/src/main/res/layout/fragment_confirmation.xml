<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/grey_background"
    tools:context=".VIEW.ConfirmationFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Title -->
        <TextView
            android:id="@+id/tv_route_title_confirmation"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:paddingBottom="16dp"
            android:textColor="@color/text_primary"
            android:textSize="20sp"
            android:textStyle="bold"
            tools:text="Vung Tau -> Ho Chi Minh City" />

        <!-- Passenger Information -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp">
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp">
                <TextView
                    android:id="@+id/passenger_info_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Passenger Information"
                    android:textColor="@color/text_primary"
                    android:textSize="18sp"
                    android:textStyle="bold" />
                <ImageView
                    android:id="@+id/edit_passenger_info_button"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_alignParentEnd="true"
                    android:src="@drawable/ic_edit"
                    app:tint="@color/text_secondary"/>
                <TextView
                    android:id="@+id/fullname_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/passenger_info_title"
                    android:layout_marginTop="16dp"
                    android:text="Fullname"
                    android:textColor="@color/text_secondary" />
                <TextView
                    android:id="@+id/fullname_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/passenger_info_title"
                    android:layout_alignParentEnd="true"
                    android:layout_marginTop="16dp"
                    android:text="Nguyen Dai Truong Danh"
                    android:textColor="@color/text_primary"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/phone_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/fullname_label"
                    android:layout_marginTop="8dp"
                    android:text="Phone"
                    android:textColor="@color/text_secondary" />
                <TextView
                    android:id="@+id/phone_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/fullname_value"
                    android:layout_alignParentEnd="true"
                    android:layout_marginTop="8dp"
                    android:text="0968411942"
                    android:textColor="@color/text_primary"
                    android:textStyle="bold" />
            </RelativeLayout>
        </androidx.cardview.widget.CardView>

        <!-- Trip Info Card -->
        <include android:id="@+id/trip_info_card" layout="@layout/item_trip" android:layout_marginTop="16dp" android:layout_width="match_parent" android:layout_height="wrap_content"/>

        <!-- Seat Number Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardCornerRadius="16dp">
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Seat number"
                    android:layout_centerVertical="true"
                    android:textColor="@color/text_secondary"/>
                <TextView
                    android:id="@+id/seat_number_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:layout_toStartOf="@id/edit_seat_button"
                    android:layout_marginEnd="8dp"
                    android:layout_centerVertical="true"
                    tools:text="15, 16"/>
                <ImageView
                    android:id="@+id/edit_seat_button"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_edit"
                    android:layout_alignParentEnd="true"
                    app:tint="@color/text_secondary"/>
            </RelativeLayout>
        </androidx.cardview.widget.CardView>


        <!-- Pick up and Drop off Information -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Pick up and drop off information"
            android:textColor="@color/text_primary"
            android:textSize="18sp"
            android:textStyle="bold" />

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            app:cardCornerRadius="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Pickup Section -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Pickup"
                    android:textColor="@color/text_primary"
                    android:textStyle="bold" />

                <RadioGroup
                    android:id="@+id/pickup_radio_group"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="8dp">
                    <RadioButton
                        android:id="@+id/pickup_bus_station_radio"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Bus Station"
                        android:checked="true"/>
                    <RadioButton
                        android:id="@+id/pickup_shuttle_radio"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:text="Shuttle Service"/>
                </RadioGroup>

                <Spinner
                    android:id="@+id/pickup_location_spinner"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"/>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/divider"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="16dp"/>

                <!-- Dropoff Section -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Dropoff"
                    android:textColor="@color/text_primary"
                    android:textStyle="bold" />
                <RadioGroup
                    android:id="@+id/dropoff_radio_group"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="8dp">
                    <RadioButton
                        android:id="@+id/dropoff_bus_station_radio"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Bus Station"
                        android:checked="true"/>
                    <RadioButton
                        android:id="@+id/dropoff_shuttle_radio"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:text="Shuttle Service"/>
                </RadioGroup>

                <Spinner
                    android:id="@+id/dropoff_location_spinner"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"/>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="I have read, understood, and agreed to the Privacy Policy"
            android:layout_marginTop="16dp"
            android:gravity="center"/>

        <Button
            android:id="@+id/final_continue_button"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginTop="16dp"
            android:text="Continue"
            android:textColor="@color/white"
            app:backgroundTint="@color/orange_primary"/>

    </LinearLayout>
</ScrollView>
    