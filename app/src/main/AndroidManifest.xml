<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    package="com.example.login">
    <!-- Thay "com.yourdomain.bookingapp" bằng package name thực tế của bạn -->

    <!--
     Khai báo các quyền mà ứng dụng cần.
     INTERNET là bắt buộc để giao tiếp với server.
     ACCESS_FINE_LOCATION/ACCESS_COARSE_LOCATION thường cần thiết cho các ứng dụng đặt xe
     để xác định vị trí người dùng.
    -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />


    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.BookingApp"
        tools:targetApi="31">
        <!--
        Khai báo MainActivity.
        Đây là Activity chính chứa các Fragment của bạn.
        -->
        <activity
            android:name="com.example.login.VIEW.MainActivity"
            android:exported="true">
            <!--
             Intent filter này chỉ định rằng MainActivity là điểm vào (entry point) của ứng dụng.
             Nó sẽ là màn hình được khởi chạy khi người dùng nhấn vào biểu tượng ứng dụng.
            -->
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!--
        Nếu bạn có các Activity khác (ví dụ: màn hình chi tiết, màn hình đăng nhập),
        bạn sẽ cần khai báo chúng ở đây.
        Ví dụ:
        <activity android:name=".DetailActivity" />
        -->

    </application>

</manifest>
    